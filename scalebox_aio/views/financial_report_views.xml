<odoo>

    <record id="view_sb_financial_report_form" model="ir.ui.view">
        <field name="name">scalebox.financial.report.form</field>
        <field name="model">scalebox.financial.report</field>
        <field name="arch" type="xml">
            <form string="Financial Reports">
                <group>
                    <group>
                        <field name="report_type" widget="radio"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="date_from"
                               invisible="report_type == 'bs'"
                               required="report_type != 'bs'"/>
                        <field name="date_to"/>
                    </group>
                </group>
                <field name="line_ids" invisible="not line_ids" readonly="1">
                    <list decoration-bf="style in ('header', 'total')"
                          decoration-primary="style == 'header'"
                          create="0" edit="0" delete="0">
                        <field name="name"/>
                        <field name="balance"/>
                        <field name="currency_id" column_invisible="1"/>
                        <field name="style" column_invisible="1"/>
                    </list>
                </field>
                <footer>
                    <button name="action_generate" type="object" string="View Report"
                            class="btn-primary"/>
                    <button name="action_print" type="object" string="Print PDF"
                            class="btn-secondary" icon="fa-print"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sb_financial_report" model="ir.actions.act_window">
        <field name="name">Financial Reports</field>
        <field name="res_model">scalebox.financial.report</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
