<odoo>

    <!-- ===================== Expense Types (===================== -->
    <record id="view_scalebox_expense_type_list" model="ir.ui.view">
        <field name="name">scalebox.expense.type.list</field>
        <field name="model">scalebox.expense.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="account_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="action_scalebox_expense_type" model="ir.actions.act_window">
        <field name="name">Expense Types</field>
        <field name="res_model">scalebox.expense.type</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create an expense type</p>
            <p>Example: buffet, cleaning, transportation expenses — and map each type to its account in the chart of accounts.</p>
        </field>
    </record>

    <!-- ===================== Expenses ===================== -->
    <record id="view_scalebox_expense_list" model="ir.ui.view">
        <field name="name">scalebox.expense.list</field>
        <field name="model">scalebox.expense</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="date"/>
                <field name="expense_type_id"/>
                <field name="description"/>
                <field name="partner_id" optional="show"/>
                <field name="pay_method" optional="show"/>
                <field name="amount" sum="Total"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'draft'"
                       decoration-danger="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <record id="view_scalebox_expense_form" model="ir.ui.view">
        <field name="name">scalebox.expense.form</field>
        <field name="model">scalebox.expense</field>
        <field name="arch" type="xml">
            <form string="Expense">
                <header>
                    <button name="action_confirm" type="object" string="Post"
                            class="btn-primary" invisible="state != 'draft'"
                            confirm="The journal entry will be posted automatically. Continue?"/>
                    <button name="action_print_receipt" type="object" string="Print Voucher"
                            class="btn-secondary" invisible="state != 'done'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state != 'done'"
                            groups="scalebox_aio.group_scalebox_manager"/>
                    <button name="action_draft" type="object" string="Reset to Draft"
                            invisible="state != 'cancel'"
                            groups="scalebox_aio.group_scalebox_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_move" type="object"
                                class="oe_stat_button" icon="fa-book"
                                invisible="not move_id" string="Journal Entry"/>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="expense_type_id" readonly="state != 'draft'"/>
                            <field name="description" readonly="state != 'draft'"/>
                            <field name="amount" readonly="state != 'draft'"/>
                            <field name="date" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="pay_method" widget="radio" readonly="state != 'draft'"/>
                            <field name="journal_id"
                                   invisible="pay_method != 'cash_bank'"
                                   required="pay_method == 'cash_bank'"
                                   readonly="state != 'draft'"/>
                            <field name="custody_account_id"
                                   invisible="pay_method != 'custody'"
                                   required="pay_method == 'custody'"
                                   readonly="state != 'draft'"/>
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="user_id" readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company"
                                   readonly="state != 'draft'"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="Notes..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_scalebox_expense_search" model="ir.ui.view">
        <field name="name">scalebox.expense.search</field>
        <field name="model">scalebox.expense</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
                <field name="expense_type_id"/>
                <field name="partner_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Posted" name="done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="This Month" name="this_month"
                        domain="[('date', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Expense Type" name="group_type" context="{'group_by': 'expense_type_id'}"/>
                    <filter string="Payment Method" name="group_pay" context="{'group_by': 'pay_method'}"/>
                    <filter string="Month" name="group_month" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_scalebox_expense" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">scalebox.expense</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Record your first expense</p>
            <p>Select the expense type and payment method; the system posts the journal entry automatically and prints the voucher.</p>
        </field>
    </record>

</odoo>
