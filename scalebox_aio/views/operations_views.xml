<odoo>

    <!-- ===================== Customers ===================== -->
    <record id="action_scalebox_customers" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('customer_rank', '&gt;', 0)]</field>
        <field name="context">{'default_customer_rank': 1, 'res_partner_search_mode': 'customer'}</field>
    </record>

    <record id="action_scalebox_vendors" model="ir.actions.act_window">
        <field name="name">Vendors</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('supplier_rank', '&gt;', 0)]</field>
        <field name="context">{'default_supplier_rank': 1, 'res_partner_search_mode': 'supplier'}</field>
    </record>

    <!-- ===================== Inventory (product / stock) ===================== -->
    <record id="action_scalebox_products" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'default_sale_ok': True, 'default_purchase_ok': True}</field>
    </record>

    <record id="action_scalebox_stock_quants" model="ir.actions.act_window">
        <field name="name">Stock On Hand</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">list,pivot</field>
        <field name="domain">[('location_id.usage', '=', 'internal')]</field>
        <field name="context">{'create': False}</field>
    </record>

    <record id="action_scalebox_pickings" model="ir.actions.act_window">
        <field name="name">Stock Operations</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_scalebox_stock_moves_report" model="ir.actions.act_window">
        <field name="name">Stock Moves Report</field>
        <field name="res_model">stock.move</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="domain">[('state', '=', 'done')]</field>
        <field name="context">{'create': False}</field>
    </record>

    <!-- ===================== Accounting (account) ===================== -->
    <record id="action_scalebox_customer_invoices" model="ir.actions.act_window">
        <field name="name">Customer Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('move_type', 'in', ('out_invoice', 'out_refund'))]</field>
        <field name="context">{'default_move_type': 'out_invoice'}</field>
    </record>

    <record id="action_scalebox_vendor_bills" model="ir.actions.act_window">
        <field name="name">Vendor Bills</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('move_type', 'in', ('in_invoice', 'in_refund'))]</field>
        <field name="context">{'default_move_type': 'in_invoice'}</field>
    </record>

    <record id="action_scalebox_journal_entries" model="ir.actions.act_window">
        <field name="name">Journal Entries</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('move_type', '=', 'entry')]</field>
        <field name="context">{'default_move_type': 'entry'}</field>
    </record>

    <record id="action_scalebox_payments" model="ir.actions.act_window">
        <field name="name">Receipts &amp; Payment Vouchers</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_scalebox_chart_of_accounts" model="ir.actions.act_window">
        <field name="name">Chart of Accounts</field>
        <field name="res_model">account.account</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ===================== ===================== -->
    <record id="action_scalebox_general_ledger" model="ir.actions.act_window">
        <field name="name">General Ledger</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">list,pivot</field>
        <field name="domain">[('parent_state', '=', 'posted')]</field>
        <field name="context">{'create': False, 'search_default_group_by_account': 1}</field>
    </record>

    <record id="action_scalebox_cash_bank_report" model="ir.actions.act_window">
        <field name="name">Cash &amp; Bank Movements</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">list,pivot</field>
        <field name="domain">[
            ('parent_state', '=', 'posted'),
            ('account_id.account_type', '=', 'asset_cash')
        ]</field>
        <field name="context">{'create': False, 'search_default_group_by_account': 1}</field>
    </record>

    <!-- ===================== Sales Reports ===================== -->
    <record id="action_scalebox_sale_report" model="ir.actions.act_window">
        <field name="name">Sales Reports</field>
        <field name="res_model">sale.report</field>
        <field name="view_mode">graph,pivot</field>
        <field name="context">{'create': False}</field>
    </record>

    <record id="action_scalebox_purchase_report" model="ir.actions.act_window">
        <field name="name">Purchase Reports</field>
        <field name="res_model">purchase.report</field>
        <field name="view_mode">graph,pivot</field>
        <field name="context">{'create': False}</field>
    </record>

    <!-- ===================== Expenses Report ===================== -->
    <record id="action_scalebox_expense_report" model="ir.actions.act_window">
        <field name="name">Expenses Report</field>
        <field name="res_model">scalebox.expense</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="domain">[('state', '=', 'done')]</field>
        <field name="context">{'create': False, 'search_default_group_type': 1}</field>
    </record>

    <!-- ===================== ===================== -->
    <record id="action_scalebox_customer_payments" model="ir.actions.act_window">
        <field name="name">Customer Payments</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('partner_type', '=', 'customer')]</field>
        <field name="context">{'default_partner_type': 'customer', 'default_payment_type': 'inbound'}</field>
    </record>

    <record id="action_scalebox_vendor_payments" model="ir.actions.act_window">
        <field name="name">Vendor Payments</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('partner_type', '=', 'supplier')]</field>
        <field name="context">{'default_partner_type': 'supplier', 'default_payment_type': 'outbound'}</field>
    </record>

    <!-- ===================== Point of Sale ===================== -->
    <record id="action_scalebox_pos_config" model="ir.actions.act_window">
        <field name="name">Point of Sale</field>
        <field name="res_model">pos.config</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Open a selling session</p>
            <p>Click a point of sale then "New Session" to open the full cashier screen.</p>
        </field>
    </record>

    <record id="action_scalebox_pos_sessions" model="ir.actions.act_window">
        <field name="name">POS Sessions</field>
        <field name="res_model">pos.session</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_scalebox_pos_orders" model="ir.actions.act_window">
        <field name="name">POS Orders</field>
        <field name="res_model">pos.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_scalebox_pos_report" model="ir.actions.act_window">
        <field name="name">POS Reports</field>
        <field name="res_model">report.pos.order</field>
        <field name="view_mode">graph,pivot</field>
        <field name="context">{'create': False}</field>
    </record>

    <!-- ===================== Journals Settings ===================== -->
    <record id="action_scalebox_journals" model="ir.actions.act_window">
        <field name="name">Journals Settings</field>
        <field name="res_model">account.journal</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_scalebox_journal_items" model="ir.actions.act_window">
        <field name="name">Journal Items</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">list,pivot</field>
        <field name="context">{'create': False}</field>
    </record>

    <!-- ===================== Inventory Settings ===================== -->
    <record id="action_scalebox_warehouses" model="ir.actions.act_window">
        <field name="name">Warehouses</field>
        <field name="res_model">stock.warehouse</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_scalebox_locations" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">stock.location</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_scalebox_routes" model="ir.actions.act_window">
        <field name="name">Routes</field>
        <field name="res_model">stock.route</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_scalebox_picking_types" model="ir.actions.act_window">
        <field name="name">Operation Types</field>
        <field name="res_model">stock.picking.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ===================== ===================== -->
    <record id="action_scalebox_receipts" model="ir.actions.act_window">
        <field name="name">Receipts</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('picking_type_code', '=', 'incoming')]</field>
    </record>

    <record id="action_scalebox_deliveries" model="ir.actions.act_window">
        <field name="name">Deliveries</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('picking_type_code', '=', 'outgoing')]</field>
    </record>

    <record id="action_scalebox_internal_transfers" model="ir.actions.act_window">
        <field name="name">Internal Transfers</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('picking_type_code', '=', 'internal')]</field>
    </record>

    <record id="action_scalebox_physical_inventory" model="ir.actions.act_window">
        <field name="name">Physical Inventory</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">list</field>
        <field name="domain">[('location_id.usage', '=', 'internal')]</field>
        <field name="context">{'inventory_mode': True}</field>
    </record>

    <record id="action_scalebox_landed_costs" model="ir.actions.act_window">
        <field name="name">Landed Costs (Shipping &amp; Customs)</field>
        <field name="res_model">stock.landed.cost</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ===================== ===================== -->
    <record id="action_scalebox_product_categories" model="ir.actions.act_window">
        <field name="name">Product Categories</field>
        <field name="res_model">product.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_scalebox_uom" model="ir.actions.act_window">
        <field name="name">Units of Measure</field>
        <field name="res_model">uom.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_scalebox_pricelists" model="ir.actions.act_window">
        <field name="name">Pricelists</field>
        <field name="res_model">product.pricelist</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_scalebox_loyalty" model="ir.actions.act_window">
        <field name="name">Discount &amp; Loyalty Programs</field>
        <field name="res_model">loyalty.program</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
