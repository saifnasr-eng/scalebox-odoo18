    <record id="action_sb_purchase_return" model="ir.actions.act_window">
        <field name="name">Purchase Returns</field>
        <field name="res_model">scalebox.easy.purchase.return</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Record your first purchase return</p>
            <p>Select the original purchase; the system posts the debit note and returns stock to the vendor automatically.</p>
        </field>
    </record>

