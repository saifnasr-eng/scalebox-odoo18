<odoo>

    <!-- ===================== Product Stock Card ===================== -->
    <record id="view_sb_stock_card_form" model="ir.ui.view">
        <field name="name">scalebox.stock.card.form</field>
        <field name="model">scalebox.stock.card</field>
        <field name="arch" type="xml">
            <form string="Product Stock Card">
                <group>
                    <group>
                        <field name="product_id"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                </group>
                <group invisible="not line_ids and opening_qty == 0">
                    <group>
                        <field name="opening_qty"/>
                        <field name="total_in"/>
                    </group>
                    <group>
                        <field name="closing_qty"/>
                        <field name="total_out"/>
                    </group>
                </group>
                <field name="line_ids" invisible="not line_ids" readonly="1">
                    <list create="0" edit="0" delete="0">
                        <field name="date"/>
                        <field name="reference"/>
                        <field name="partner_id"/>
                        <field name="qty_in" sum="Total In"/>
                        <field name="qty_out" sum="Total Out"/>
                        <field name="balance"/>
                    </list>
                </field>
                <footer>
                    <button name="action_generate" type="object" string="View" class="btn-primary"/>
                    <button name="action_print" type="object" string="Print PDF" class="btn-secondary" icon="fa-print"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sb_stock_card" model="ir.actions.act_window">
        <field name="name">Product Stock Card</field>
        <field name="res_model">scalebox.stock.card</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ===================== Report Detailed ===================== -->
    <record id="view_sb_detail_report_form" model="ir.ui.view">
        <field name="name">scalebox.detail.report.form</field>
        <field name="model">scalebox.detail.report</field>
        <field name="arch" type="xml">
            <form string="Detailed Report">
                <group>
                    <group>
                        <field name="report_type" widget="radio"/>
                        <field name="partner_id"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                </group>
                <field name="line_ids" invisible="not line_ids" readonly="1">
                    <list create="0" edit="0" delete="0"
                          decoration-danger="doc_kind == 'return'">
                        <field name="date"/>
                        <field name="name"/>
                        <field name="partner_id"/>
                        <field name="doc_kind"/>
                        <field name="amount_untaxed" sum="Untaxed"/>
                        <field name="amount_tax" sum="Tax"/>
                        <field name="amount_total" sum="Total"/>
                        <field name="currency_id" column_invisible="1"/>
                    </list>
                </field>
                <group invisible="not line_ids" class="oe_subtotal_footer">
                    <field name="gross_total" readonly="1"/>
                    <field name="returns_total" readonly="1"/>
                    <field name="net_total" readonly="1" class="oe_subtotal_footer_separator"/>
                </group>
                <footer>
                    <button name="action_generate" type="object" string="View" class="btn-primary"/>
                    <button name="action_print" type="object" string="Print PDF" class="btn-secondary" icon="fa-print"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sb_detail_report_sale" model="ir.actions.act_window">
        <field name="name">Detailed Sales Report</field>
        <field name="res_model">scalebox.detail.report</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'sale'}</field>
    </record>

    <record id="action_sb_detail_report_purchase" model="ir.actions.act_window">
        <field name="name">Detailed Purchases Report</field>
        <field name="res_model">scalebox.detail.report</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'purchase'}</field>
    </record>

</odoo>
